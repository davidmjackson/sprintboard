{
  /* Tests are typechecked, but not by the app project: they run in Node, not the
     browser, so they need node types the app must never see. Keeping them in
     tsconfig.app.json is what let `import 'node:fs'` fail the build. */
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    /* vite/client too: tests import app modules, and env.ts reads import.meta.env. */
    "types": ["node", "vitest/globals", "vite/client"],
    "skipLibCheck": true,

    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "noUncheckedIndexedAccess": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/test"]
}
