# Copy to .env.local and fill in. .env.local is gitignored.
#
# Both values below are safe to expose: they ship to the browser in every
# request. The security boundary is owner-scoped RLS in the database, not
# secrecy of these keys.
#
# NEVER put the service-role / sb_secret_ key here. It bypasses RLS entirely.
# src/lib/env.ts detects one and refuses to boot, but do not rely on that.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# S1.3 RLS isolation test. Two pre-created, auto-confirmed Supabase users.
# NOT VITE_-prefixed, deliberately: Vite inlines VITE_* into the browser bundle,
# so a VITE_-prefixed password would ship to every visitor.
RLS_TEST_A_EMAIL=rls-a@example.com
RLS_TEST_A_PASSWORD=
RLS_TEST_B_EMAIL=rls-b@example.com
RLS_TEST_B_PASSWORD=

# S2.1 signup integration test. The service-role key, used test-side only to verify
# the auto-created profile and delete the throwaway signup user.
#
# This is NOT a contradiction of the warning at the top of this file. That warning
# is about the *browser* slot (VITE_SUPABASE_ANON_KEY): the service-role key must
# never go THERE, because VITE_* is inlined into dist/ and shipped to every visitor.
# THIS slot is NOT VITE_-prefixed, so it is never inlined — it stays in the test
# process (and CI's server-side runner), never the bundle. check-bundle.mjs remains
# the backstop that fails the build if a privileged key ever reaches the browser.
SUPABASE_SERVICE_ROLE_KEY=
